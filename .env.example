# ─── PostgreSQL (DigitalOcean) ────────────────────────────────────────────────
OPS_DB_HOST=your-do-postgres-host.db.ondigitalocean.com
OPS_DB_PORT=25060
OPS_DB_USER=your-db-user
OPS_DB_PASSWORD=your-db-password
OPS_DB_NAME=your-db-name
# Optional local-development override. Production defaults to SSL.
OPS_DB_SSL=true

# ─── Chargebee ────────────────────────────────────────────────────────────────
CHARGEBEE_SITE=your-chargebee-site
CHARGEBEE_API_KEY=your-chargebee-api-key
CHARGEBEE_WEBHOOK_USERNAME=nomadops_chargebee
CHARGEBEE_WEBHOOK_PASSWORD=generate-a-long-random-password
COLLECTIONS_SCHEDULER_SECRET=generate-a-separate-long-random-secret

# ─── Verizon ThingSpace ───────────────────────────────────────────────────────
THINGSPACE_CLIENT_ID=your-thingspace-client-id
THINGSPACE_CLIENT_SECRET=your-thingspace-client-secret
THINGSPACE_ACCOUNT_NAME=your-thingspace-account-name
THINGSPACE_USERNAME=your-thingspace-username
THINGSPACE_PASSWORD=your-thingspace-password

# ─── FreeScout ────────────────────────────────────────────────────────────────
FREESCOUT_API_URL=https://your-freescout-instance.com/api
FREESCOUT_API_KEY=your-freescout-api-key

# ─── Twilio Call Verification ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your-twilio-api-key-secret
TWILIO_CALL_VERIFICATION_ENABLED=false

# ─── Shopify ─────────────────────────────────────────────────────────────────
SHOPIFY_ADMIN_KEY=your-shopify-admin-api-token
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# ─── ShipStation ─────────────────────────────────────────────────────────────
SHIPSTATION_API_KEY=your-shipstation-api-key
SHIPSTATION_API_SECRET=your-shipstation-api-secret

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
